/* pages/anli/anli.wxss */
.topSwiper{
  position: absolute;
  top: 0rpx;
  left: 0rpx;
  width: 100%;
  background: url('https://p0.itc.cn/q_70/images03/20210530/268d4dee05e44f1fb9617a5120c6d885.jpeg');
  background-size: 100%;
}
.notice-swiper {
  width: 100%;
  height: fit-content;
  /* float: right; */
  overflow: hidden;
  position: relative;
}
.notice-position {
  width: 100%;
  float: left;
  position: absolute;
}
.notice-for {
  width: 100%;
  float: left;
  height: 40px;
}
.notice-item-root-container {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 40px;
}
.notice-item-container {
  width: 100%;
  height: 40px;
  display: flex;
  flex-direction: row;
}
.notice-line-item-container {
  height: 100%;
  flex: 1;
  display: flex;
  flex-direction: row;
  overflow: hidden;
  max-lines: 1;
  white-space: nowrap;
  justify-content:center;
}
.notice-line-item{
  margin-left: 6rpx;
  margin-right: 6rpx;
  font-size: 40rpx;
  font-family: PingFang SC;
  font-weight: 500;
  text-align: right;
  color: #fff;
  width: fit-content;
  display: flex;
  flex-direction: row;
  height: 100%;
  overflow: hidden;
  line-height: 40rpx;
  max-lines: 1;
  white-space: nowrap;
}
.anliItem{
  margin: 30rpx 20rpx;
}
.anliTitle{
  font-weight: bold;
  margin: 10rpx 0rpx;
}
.anliContent{
  font-size: 30rpx;
}

.container{
  position:fixed;
  width:100%;
  height:100%;
  background-color:#FFF;
  margin-top: 300rpx;
}
.nav_left{
  width:25%;
  height:100%;
  background:#F2F2F2;
  text-align:center;
  position:absolute;
  top:0;
  left:0;
}
.nav_left .nav_left_items{
  height:100rpx;
  line-height:100rpx;
  font-size:28rpx;
}
.nav_left .nav_left_items.active{
  position:relative;
  background:#FFF;
  color:#FF5000;
}
.nav_left .nav_left_items.active::before{
  display: inline-block;
  width:6rpx;
  height:60rpx;
  background:#FE5723;
  content:'';
  position:absolute;
  top:20rpx;
  left:0;
}
.nav_right{
  position:absolute;
  top:0;
  right:0;
  width:75%;
  height:100%;
}
.nav_right .nav_right_items{
  float: left;   
  width: 33.33%; 
  text-align: center;  
  padding:30rpx 0;
} 
.nav_right .nav_right_items image{
  width: 120rpx;  
  height: 120rpx; 
} 
.nav_right .nav_right_items text{
  display: block;  
  margin-top: 20rpx;  
  font-size: 28rpx;  
  overflow: hidden;  
  white-space: nowrap;  
  text-overflow: ellipsis;  
} 
.nocate{
  padding:100rpx;
  text-align: center;  
} 
 
.nocate image{
  width:70rpx;
  height:70rpx;
}
.nocate text{
  font-size:28rpx;
  display:block;
  color:#BBB;
}
/*隐藏滚动条*/
::-webkit-scrollbar{
  width: 0;
  height: 0;
  color: transparent;
}